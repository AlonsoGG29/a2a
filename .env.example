# ============================================================
# Sports A2A — Environment Configuration
# ============================================================

# Azure AI Foundry — required for the server and orchestrator client
FOUNDRY_PROJECT_ENDPOINT=https://your-project.services.ai.azure.com/api/projects/your-project
FOUNDRY_MODEL=gpt-4o-mini

# A2A client (simple client) — URL of the results server
A2A_AGENT_HOST=http://localhost:5001/

# A2A orchestrator client — URLs for both servers
A2A_RESULTS_HOST=http://localhost:5001/
A2A_STATS_HOST=http://localhost:5002/